# Environment variables for the authentication service

PORT = 8080
ACCESS_KEY = accessToken_secretKey
REFRESH_KEY = accessRefresh_secretKey

# Eureka Configuration 
EUREKA_HOST=localhost
EUREKA_PORT=8761

# Network Configuration 
HOSTNAME=localhost
IP=127.0.0.1

# Service URLs (using Eureka VIP addresses)
AUTH_SERVICE_URL=http://localhost:7000
AUTH_SERVICE_NAME=SERVICE1-AUTH

POSTS_SERVICE_URL=http://localhost:7001
POSTS_SERVICE_NAME=SERVICE2-POSTS

CONTENT_SERVICE_URL=http://localhost:7002
CONTENT_SERVICE_NAME=SERVICE3-CONTENT

NOTIFICATIONS_SERVICE_URL=http://localhost:7003
NOTIFICATIONS_SERVICE_NAME=SERVICE4-NOTIFICATION